{
  "name": "@hanzo/mdx-runtime",
  "version": "1.6.0",
  "description": "Runtime MDX compilation and execution for Hanzo Docs",
  "keywords": [
    "Docs",
    "NextJs",
    "hanzo-docs",
    "next-mdx-remote"
  ],
  "homepage": "https://hanzo.ai/docs",
  "license": "MIT",
  "author": "Fuma Nama",
  "repository": "github:hanzoai/docs",
  "files": [
    "dist/*"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "gray-matter": "^4.0.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "24.10.2",
    "@types/react": "^19.2.7",
    "eslint-config-custom": "workspace:*",
    "@hanzo/docs-core": "workspace:*",
    "react": "^19.2.3",
    "tinyglobby": "^0.2.15",
    "tsconfig": "workspace:*",
    "tsdown": "^0.18.3",
    "unified": "^11.0.5",
    "vfile": "^6.0.3"
  },
  "peerDependencies": {
    "@types/react": "*",
    "@hanzo/docs-core": "^15.0.0 || ^16.0.0",
    "react": "18.x.x || 19.x.x"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  }
}
