{
  "name": "@hanzo/docs-brand",
  "version": "1.0.0",
  "description": "Brand configuration system for Hanzo, Lux, and Zoo documentation",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./hanzo": {
      "import": "./dist/brands/hanzo.js",
      "types": "./dist/brands/hanzo.d.ts"
    },
    "./lux": {
      "import": "./dist/brands/lux.js",
      "types": "./dist/brands/lux.d.ts"
    },
    "./zoo": {
      "import": "./dist/brands/zoo.js",
      "types": "./dist/brands/zoo.d.ts"
    },
    "./css/*": "./css/*"
  },
  "files": [
    "dist/*",
    "css/*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "fumadocs-ui": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "eslint-config-custom": "workspace:*",
    "react": "^19.2.0",
    "tsconfig": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  }
}
