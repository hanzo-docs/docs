{
  "name": "@hanzo/docs-cli",
  "version": "1.3.2",
  "description": "The CLI tool for Hanzo Docs",
  "keywords": [
    "Docs",
    "Hanzo Docs"
  ],
  "homepage": "https://docs.hanzo.ai",
  "license": "MIT",
  "author": "Hanzo Nama",
  "repository": "github:hanzoai/docs",
  "bin": {
    "docs-cli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./build": "./dist/build.js",
    "./config": "./dist/config.js",
    "./registry/installer": "./dist/registry/installer.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "commander": "^14.0.3",
    "fuma-cli": "^0.1.1",
    "picocolors": "^1.1.1",
    "tinyexec": "^1.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.0"
  }
}
