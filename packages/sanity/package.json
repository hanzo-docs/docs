{
  "name": "@hanzo/docs-sanity",
  "version": "0.0.5",
  "description": "The official Sanity integration for Hanzo Docs",
  "keywords": [
    "Docs",
    "Hanzo Docs"
  ],
  "homepage": "https://docs.hanzo.ai",
  "license": "MIT",
  "author": "Hanzo Nama",
  "repository": "github:hanzoai/docs",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./client": "./dist/client.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --clean false",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@portabletext/react": "^6.2.0"
  },
  "devDependencies": {
    "@sanity/client": "^7.22.1",
    "@sanity/types": "^5.27.0",
    "@types/node": "25.9.1",
    "@types/react": "^19.2.15",
    "fuma-cli": "^0.1.1",
    "@hanzo/docs-core": "workspace:*",
    "@hanzo/docs-ui": "workspace:*",
    "next-sanity": "^13.0.6",
    "react": "^19.2.6",
    "sanity": "^5.27.0",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@sanity/client": "^7.22.0",
    "@sanity/types": "*",
    "@types/react": "*",
    "@hanzo/docs-core": "^16.8.0",
    "next-sanity": "^12.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "@sanity/types": {
      "optional": true
    },
    "@sanity/client": {
      "optional": true
    },
    "next-sanity": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  }
}
