{
  "name": "@hanzo/docs-basehub",
  "version": "0.0.1",
  "description": "The official BaseHub integration for Hanzo Docs",
  "keywords": [
    "Docs",
    "Hanzo Docs"
  ],
  "homepage": "https://docs.hanzo.ai",
  "license": "MIT",
  "author": "Hanzo Nama",
  "repository": "github:hanzoai/docs",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/toc.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch --clean false",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "^19.2.15",
    "basehub": "^9.5.3",
    "fuma-cli": "^0.1.1",
    "@hanzo/docs-core": "workspace:*",
    "@hanzo/docs-ui": "workspace:*",
    "react": "^19.2.6",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@types/react": "*",
    "basehub": "9.x.x",
    "@hanzo/docs-core": "^16.8.0",
    "react": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  }
}
