{
  "name": "@hanzo/create-docs",
  "version": "16.0.119",
  "description": "Create a new documentation site with Hanzo Docs",
  "keywords": [
    "Docs",
    "Hanzo Docs",
    "react"
  ],
  "homepage": "https://docs.hanzo.ai",
  "license": "MIT",
  "author": "Hanzo Nama",
  "repository": "github:hanzoai/docs",
  "bin": "./dist/bin.js",
  "files": [
    "dist",
    "template"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugins/*": {
      "types": "./dist/plugins/*.d.ts",
      "import": "./dist/plugins/*.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run sync && tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit",
    "sync": "node ./scripts/sync.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@hanzo/docs-cli": "workspace:*",
    "commander": "^14.0.3",
    "fuma-cli": "^0.1.1",
    "picocolors": "^1.1.1",
    "tinyexec": "^1.2.2",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "25.9.1",
    "tinyglobby": "^0.2.16",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
