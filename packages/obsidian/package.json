{
  "name": "@hanzo/docs-obsidian",
  "version": "0.0.13",
  "description": "Obsidian Integration for Hanzo Docs",
  "keywords": [
    "Docs",
    "NextJs",
    "Obsidian",
    "Hanzo Docs"
  ],
  "homepage": "https://docs.hanzo.ai",
  "license": "MIT",
  "author": "Hanzo Nama",
  "repository": "github:hanzoai/docs",
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./mdx": {
      "types": "./dist/mdx/index.d.ts",
      "import": "./dist/mdx/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "js-yaml": "^4.1.1",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwind-merge": "^3.6.0",
    "tinyglobby": "^0.2.16",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/estree": "^1.0.9",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@hanzo/docs-core": "workspace:*",
    "mdast-util-mdx": "^3.0.0",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@types/react": "*",
    "@hanzo/docs-core": "^15.0.0 || ^16.0.0",
    "react": "*",
    "react-dom": "*"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  }
}