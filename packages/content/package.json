{
  "name": "@hanzo/docs-content",
  "version": "0.0.1",
  "description": "The Fuma Content adapter for Hanzo Docs",
  "keywords": [
    "Docs",
    "Hanzo"
  ],
  "homepage": "https://docs.hanzo.ai",
  "license": "MIT",
  "repository": "github:hanzoai/docs",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./runtime": "./dist/runtime.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "fuma-content": "^1.2.3",
    "fumadocs-core": "workspace:*",
    "tsconfig": "workspace:*",
    "tsdown": "0.22.0"
  },
  "peerDependencies": {
    "fuma-content": "^1.2.3",
    "fumadocs-core": "^16.6.17"
  }
}