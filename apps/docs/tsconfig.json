{
  "extends": "tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@hanzo/mdx:collections/*": [".docs/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "content/**/*.mdx", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "eslint.config.mjs", "components/registry/**/*"]
}
