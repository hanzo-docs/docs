# Cloudflare Pages redirects — the single source of truth for docs.hanzo.ai
# HTTP redirects. This site deploys as a static export (`out/`), which ignores
# next.config `redirects()`, so this file is what runs in production — exactly
# like the sibling public/_headers.

# API reference: the canonical page is the single-page OpenAPI reference at
# /docs/openapi. Send every intuitive/guessed alias there so it always resolves.
/docs/api          /docs/openapi          301
/docs/api/*        /docs/openapi          301
/api               /docs/openapi          301
/api/*             /docs/openapi          301
/api-reference     /docs/openapi          301
/api-reference/*   /docs/openapi          301

# Tutorials were merged into Services.
/tutorials         /docs/services         301
/tutorials/*       /docs/services/:splat  301

# Top-level convenience aliases. docs.hanzo.ai is already the docs subdomain, so
# bare product paths resolve to their canonical page under /docs. Explicit list
# only — never a catch-all, which would shadow /, /blog, /showcase, /login.
/introduction      /docs/getting-started  301
/quickstart        /docs/getting-started  301
/getting-started   /docs/getting-started  301
/gpus              /docs/gpus             301
/gpu               /docs/gpus             301
/models            /docs/llm              301
/chat              /docs/chat             301
/agents            /docs/agents           301
/mcp               /docs/mcp              301
/sdks              /docs/sdks             301
/llm               /docs/llm              301

# Console product "Docs" deep-links (console registry uses /docs/<product>).
# Where the canonical page lives under /docs/services or /docs/projects, alias it
# so the console's Docs button always resolves.
/docs/analytics    /docs/services/analytics         301
/docs/auto         /docs/services/auto              301
/docs/cms          /docs/projects/hanzoai/cms       301
/docs/helpdesk     /docs/projects/hanzoai/helpdesk  301
/docs/apm          /docs/services/o11y              301
/docs/apps         /docs/services/paas              301
/docs/nodes        /docs/services/visor             301

# Console module "Docs" buttons that link bare product paths (docsUrl + '/x').
/crawl             /docs/services/search            301
/functions         /docs/functions                  301
/kms               /docs/services/kms               301

# QA: guessed program slugs → real pages (getting-started covers the /startup
# on-ramp; deploy lives under the platform/paas services docs).
/docs/startups     /docs/getting-started      301
/docs/deploy       /docs/services/paas        301
