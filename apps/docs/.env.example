# Search backend: "meilisearch" (default, direct) or "cloud" (via cloud-api proxy)
# NEXT_PUBLIC_HANZO_SEARCH_BACKEND="meilisearch"

# For meilisearch backend (default):
# NEXT_PUBLIC_HANZO_SEARCH_ENDPOINT="https://search.hanzo.ai"
# NEXT_PUBLIC_HANZO_SEARCH_KEY="<meilisearch-search-api-key>"
# NEXT_PUBLIC_HANZO_SEARCH_INDEX="app-docs-hanzo-ai-docs"

# For cloud backend:
# NEXT_PUBLIC_HANZO_SEARCH_ENDPOINT="https://cloud-api.hanzo.ai/api/search-docs"
# NEXT_PUBLIC_HANZO_SEARCH_KEY="pk-hanzo-docs-search-2026"

# Chat endpoint (requires cloud-api)
# NEXT_PUBLIC_HANZO_CHAT_ENDPOINT="https://cloud-api.hanzo.ai/api/chat-docs"

# Post-build index sync (admin key for write access)
# HANZO_SEARCH_ADMIN_KEY=<master-key-or-hk-key>
# HANZO_SEARCH_BACKEND="meilisearch"
# HANZO_SEARCH_INDEX_ENDPOINT="https://search.hanzo.ai"
# HANZO_SEARCH_INDEX="app-docs-hanzo-ai-docs"
