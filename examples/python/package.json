{
  "name": "example-python",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm build:docs && next build",
    "dev": "next dev",
    "start": "next start",
    "build:docs": "pnpm python:generate && node ./scripts/generate-docs.mjs",
    "python:generate": "pip3 install ./node_modules/@hanzo/docs-python && fumapy-generate httpx",
    "types:check": "@hanzo/docs-mdx && tsc --noEmit"
  },
  "dependencies": {
    "@hanzo/docs-core": "workspace:*",
    "@hanzo/docs-mdx": "workspace:*",
    "@hanzo/docs-python": "workspace:*",
    "@hanzo/docs-ui": "workspace:*",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
