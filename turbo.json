{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "HANZO_PUBLISHABLE_KEY",
    "GITHUB_APP_PRIVATE_KEY",
    "GITHUB_APP_ID",
    "GITHUB_TOKEN"
  ],
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_EXPORT",
        "GITHUB_PAGES",
        "DOCS_SECTION",
        "ANALYZE",
        "HANZO_DOCS_*",
        "HANZO_SEARCH_*"
      ],
      "passThroughEnv": ["NODE_OPTIONS"],
      "outputs": [
        ".output",
        "public/registry",
        ".source/**",
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "css/generated/**",
        "out",
        "build",
        ".vercel"
      ]
    },
    "lint": {},
    "types:check": {
      "dependsOn": [],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
